/db/*.sqlite3
/db/*.sqlite3-journal
.byebug_history
.ruby-version
.ruby-gemset

# --- Node/Frontend ---
node_modules/
/public/assets
/public/packs
/public/packs-test
yarn-error.log
yarn-debug.log*

# --- Environment/Secrets ---
.env
.env.*
config/secrets.yml
environment-var

# --- OS/IDEs ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- Other ---
.vagrant
.capistrano
Capfile
Vagrantfile
